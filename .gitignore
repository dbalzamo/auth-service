.gitignore
# ============================================================
# JAVA / SPRING BOOT
# ============================================================
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# Build output
target/
build/
out/

# ============================================================
# MAVEN / GRADLE
# ============================================================
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

.gradle/
gradle-app.setting
!gradle-wrapper.jar
.gradletasknamecache

# ============================================================
# IDE - IntelliJ IDEA
# ============================================================
.idea/
*.iws
*.iml
*.ipr

# IDE - VS Code
.vscode/
*.code-workspace

# IDE - Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# ============================================================
# OS
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================
# ENV / SECRETS
# ============================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.jks
application-local.yml
application-local.properties
application-secret*.yml
application-secret*.properties

# ============================================================
# LOGS
# ============================================================
*.log
logs/
log/

# ============================================================
# DOCKER
# ============================================================
docker-compose.override.yml

# ============================================================
# NODE / ANGULAR (frontend)
# ============================================================
node_modules/
dist/
.npm
npm-debug.log*
yarn-error.log*

# ============================================================
# PYTHON (se presente)
# ============================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/

# ============================================================
# MISC
# ============================================================
*.tmp
*.swp
*.bak
*.orig